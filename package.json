{
  "name": "cc-launch",
  "version": "0.1.10",
  "description": "Git worktree launcher with shell integration for Codex and Claude workflows",
  "bin": {
    "ccl": "bin/ccl"
  },
  "files": [
    "bin",
    "ccl-core.sh",
    "ccl-shell.sh",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bash ./scripts/test-worktree-root.sh && bash ./scripts/test-merged-branch-detection.sh && bash ./scripts/test-existing-branch-worktree.sh",
    "pack:dry-run": "npm pack --dry-run",
    "release": "bash ./scripts/release.sh"
  },
  "keywords": [
    "git",
    "worktree",
    "cli",
    "codex",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/panjiangyi/cc-launcher.git"
  },
  "homepage": "https://github.com/panjiangyi/cc-launcher#readme",
  "bugs": {
    "url": "https://github.com/panjiangyi/cc-launcher/issues"
  },
  "license": "MIT"
}
